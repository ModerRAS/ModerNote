<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:proto="using:Modernote.Protocol"
        x:Class="Modernote.Desktop.MainWindow"
        x:DataType="Window"
        Title="Modernote"
        Width="1280" Height="800"
        MinWidth="800" MinHeight="600">
    <Grid RowDefinitions="*,Auto" ColumnDefinitions="280,4,*">
        <!-- Row 0: Main content (sidebar, splitter, editor) -->
        <Grid Grid.Row="0" ColumnDefinitions="280,4,*">
            <!-- Sidebar (left) -->
            <Border Grid.Column="0" x:Name="SidebarPanel" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}">
                <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto">
                    <!-- Toolbar -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="8,8,8,4" Spacing="4">
                        <Button x:Name="NewNoteButton" Content="+" Width="32" Height="28" Click="OnNewNoteClick" ToolTip.Tip="New Note"/>
                        <Button x:Name="SaveButton" Content="&#x1F4BE;" Width="32" Height="28" Click="OnSaveClick" ToolTip.Tip="Save Note"/>
                        <Button x:Name="UndoButton" Content="&#x21B6;" Width="32" Height="28" Click="OnUndoClick" ToolTip.Tip="Undo"/>
                        <Button x:Name="RedoButton" Content="&#x21B7;" Width="32" Height="28" Click="OnRedoClick" ToolTip.Tip="Redo"/>
                        <Button x:Name="ScanButton" Content="&#x21BB;" Width="32" Height="28" Click="OnScanClick" ToolTip.Tip="Scan Vault"/>
                    </StackPanel>
                    <!-- Search box -->
                    <TextBox Grid.Row="1" x:Name="SearchBox" PlaceholderText="Search..." Margin="8,4" />
                    <!-- Object tree + search results -->
                    <Grid Grid.Row="2" RowDefinitions="*,Auto">
                        <ListBox Grid.Row="0" x:Name="ObjectList" Margin="0,4,0,0">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="proto:ObjectDto">
                                    <TextBlock Text="{Binding DisplayName}" Padding="4,2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border Grid.Row="1" x:Name="SearchResultsPanel" IsVisible="False" MaxHeight="200" BorderBrush="Gray" BorderThickness="0,1,0,0">
                            <ListBox x:Name="SearchResultsList">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="proto:SearchResultDto">
                                        <StackPanel Orientation="Vertical" Margin="4,2">
                                            <TextBlock Text="{Binding Object.DisplayName}" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text="{Binding Snippet}" Opacity="0.6" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                    <!-- Import button -->
                    <Button Grid.Row="3" x:Name="ImportButton" Content="Import File..." Margin="8" HorizontalAlignment="Stretch" Click="OnImportClick"/>
                    <!-- Sidebar status info -->
                    <TextBlock Grid.Row="4" x:Name="StatusText" Margin="8,4" Text="No vault open" Opacity="0.6" FontSize="11"/>
                </Grid>
            </Border>
            <!-- Splitter -->
            <GridSplitter Grid.Column="1" ResizeDirection="Columns"/>
            <!-- Main content area (right) -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*">
                <!-- Page chrome -->
                <Border Grid.Row="0" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" Padding="12,8">
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBlock x:Name="PageTitle" Text="No note selected" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                            <Button x:Name="SaveButton" Content="Save" Click="OnSaveClick" IsEnabled="False" ToolTip.Tip="Save note (Ctrl+S)"/>
                            <Button x:Name="AddBlockButton" Content="+" Width="28" Height="28" Click="OnAddBlockClick" ToolTip.Tip="Add block"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <!-- Editor host -->
                <ScrollViewer Grid.Row="1" Padding="24" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="EditorPanel" Spacing="8">
                        <TextBlock Text="Open or create a note to start" Opacity="0.5"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
        <!-- Row 1: Status bar -->
        <Border Grid.Row="1" Grid.ColumnSpan="3" Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" Padding="8,4">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" x:Name="StatusBarInfo" Text="Ready" FontSize="11" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                    <TextBlock x:Name="StatusObjectCount" Text="" FontSize="11" Opacity="0.7"/>
                    <TextBlock x:Name="StatusSelection" Text="" FontSize="11" Opacity="0.7"/>
                    <TextBlock x:Name="StatusDirty" Text="" FontSize="11" Foreground="#CC8800"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
